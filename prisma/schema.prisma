// Prisma schema for screenshotmaker
// Single-user, SQLite, file uploads under ./data/uploads/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Template {
  id        String   @id @default(cuid())
  name      String
  slotCount Int      @default(5)
  config    String   @default("{}") // JSON blob: bg, font family, palette, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  slots     Slot[]
  projects  Project[]
}

model Slot {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order      Int
  headline   String   @default("")
  subhead    String?
  config     String   @default("{}") // JSON: normalized text position, device rotation, bg override

  @@unique([templateId, order])
  @@index([templateId])
}

model Project {
  id         String   @id @default(cuid())
  name       String
  templateId String
  template   Template @relation(fields: [templateId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  screens    Screen[]

  @@index([templateId])
}

model Screen {
  id             String  @id @default(cuid())
  projectId      String
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slotOrder      Int
  screenshotPath String

  @@unique([projectId, slotOrder])
  @@index([projectId])
}
